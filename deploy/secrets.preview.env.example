# Copy this file to deploy/secrets.preview.env and fill from Railway Dashboard.
# deploy/secrets.preview.env is gitignored — never commit real secrets.
#
# Run: npm run deploy:check

NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
ADMIN_REVENUE_SECRET=

# DATABASE_URL is usually injected by Railway Postgres — add here only if check script should validate it:
# DATABASE_URL=

# Copy to deploy/secrets.preview.env and fill from Railway (gitignored).
# Run: npm run deploy:check
#
# Replace ${{ Postgres.DATABASE_URL }} with your Railway reference or paste the full URL from the Postgres service.

DATABASE_URL=${{ Postgres.DATABASE_URL }}
NEXTAUTH_URL=https://your-app.up.railway.app
NEXTAUTH_SECRET=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
ADMIN_REVENUE_SECRET=

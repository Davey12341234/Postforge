# Copy to deploy/secrets.preview.env and fill from Railway (gitignored).
# If your editor hides this folder/file, use %USERPROFILE%\.postforge-deploy-check.env
# or DEPLOY_CHECK_FILE — see deploy/WHERE-TO-PUT-SECRETS.txt
# Run: npm run deploy:check
#
# Replace ${{ Postgres.DATABASE_URL }} with your Railway reference or paste the full URL from the Postgres service.

DATABASE_URL=${{ Postgres.DATABASE_URL }}
NEXTAUTH_URL=https://your-app.up.railway.app
# Same origin as NEXTAUTH_URL when the app needs absolute URLs for assets
APP_URL=https://your-app.up.railway.app
NEXTAUTH_SECRET=
ANTHROPIC_API_KEY=
# Required for DALL·E / GPT Image / Whisper / OpenAI chat path
OPENAI_API_KEY=
# Optional: anthropic (default) | openai
# UNIFIED_CHAT_PROVIDER=anthropic
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
ADMIN_REVENUE_SECRET=

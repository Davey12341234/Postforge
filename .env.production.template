# ============================================
# PostForge — production environment (template)
# ============================================
# Copy values into Railway Dashboard → Variables (or merge with deploy/secrets.preview.env for npm run deploy:check).
# Do NOT commit real secrets. This file is safe to commit (placeholders only).
# ============================================

NODE_ENV=production

# Public site URL (NextAuth + Stripe return URLs). No trailing slash. NOT /unified — root only.
# Example: https://yourdomain.com   or   https://your-service.up.railway.app
NEXTAUTH_URL=https://YOUR_DOMAIN_HERE
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32

# PostgreSQL — on Railway you MUST add this on the *web* service (Postgres service does not auto-inject into Postforge):
#   Variables → New → Name: DATABASE_URL  Value: ${{ Postgres.DATABASE_URL }}
#   (Replace "Postgres" with your database service name from the project graph.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# AI — Unified chat + generate
ANTHROPIC_API_KEY=sk-ant-api03-...

# Legacy Postforge (optional)
# OPENAI_API_KEY=sk-...

# Stripe — use test keys until go-live; then live keys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

ADMIN_REVENUE_SECRET=random-long-string

# Optional
# APP_URL=https://YOUR_DOMAIN_HERE
# PORT=3000

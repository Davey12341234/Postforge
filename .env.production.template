# ============================================
# PostForge — production (Railway). Copy into Railway → Variables.
# Never commit real secrets. See docs/RAILWAY-QUICK-RUN.md
# ============================================

NODE_ENV=production

# --- Required ---
# Web service: reference Postgres, OR paste full postgresql:// URL from DB service Variables.
DATABASE_URL=${{ Postgres.DATABASE_URL }}

# Public root URL only (no /unified). Example: https://your-app.up.railway.app
NEXTAUTH_URL=https://your-app.up.railway.app
# Generate: openssl rand -base64 32   (do NOT leave GENERATE_WITH_... text)
NEXTAUTH_SECRET=

ANTHROPIC_API_KEY=

# --- Stripe (Unified checkout) — use real IDs from dashboard, not pk_test_... placeholders ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

# Long random string (not the words "random-long-string")
ADMIN_REVENUE_SECRET=

# --- Optional ---
# OPENAI_API_KEY=
# Legacy Meta publishing:
# META_API_VERSION=v21.0
# EMAIL_FROM=noreply@yourdomain.com

# Redis: this app uses Upstash REST — NOT redis://localhost
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# INNGEST_EVENT_KEY=

# Do NOT set REDIS_URL=redis://localhost on Railway — wrong for this codebase.

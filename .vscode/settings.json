{
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.envFile": "${workspaceFolder}/.env.local",
  "explorer.excludeGitIgnore": false,
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true
  },
  "files.associations": {
    ".env*": "properties",
    "*.env": "properties",
    "*.env.local": "properties"
  },
  "files.simpleDialog.enable": true
}

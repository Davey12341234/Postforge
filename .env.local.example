# Copy to .env.local for BabyGPT.
#
# Preferred: Z.AI / GLM — https://open.bigmodel.cn/
# Base URL defaults if omitted.
Z_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
Z_AI_API_KEY=
#
# Fallback: if Z.AI is not configured, BabyGPT uses OpenAI Chat Completions instead
# (same UI; web_search uses DuckDuckGo lite unless Z.AI is available).
OPENAI_API_KEY=
#
# --- Gemini (file attachments + Create image) ---
# Multimodal chat with attachments and /api/gemini/image use Google Gemini. Get a key from AI Studio.
# GEMINI_API_KEY=
# Optional model overrides (defaults: gemini-2.5-flash chat, gemini-2.5-flash-image for images):
# GEMINI_CHAT_MODEL=
# GEMINI_IMAGE_MODEL=
#
# Max upload size per file (bytes). Defaults ~25 MiB when unset (sane for hosted deploys). Raise for self-host, e.g. 536870912 (512 MiB).
# In-app “Max per file” presets store babygpt_max_file_bytes_override in localStorage; keep server env >= what users can pick.
# Files over BABYGPT_INLINE_ATTACHMENT_BYTES use Gemini Files API (POST /api/gemini/files, multipart) so the chat request stays small.
# BABYGPT_INLINE_ATTACHMENT_BYTES=
# NEXT_PUBLIC_INLINE_ATTACHMENT_BYTES=
# BABYGPT_MAX_FILE_BYTES=
# NEXT_PUBLIC_MAX_FILE_BYTES=
#
# Public URL for Stripe redirects (Checkout success/cancel, Portal return). No trailing slash.
# NEXT_PUBLIC_APP_URL=https://your-domain.example
#
# --- Optional: gated deploy (server wallet + login) ---
# If set, users must sign in at /login; credits & plan are stored under BABYGPT_DATA_DIR (default .data/).
# No extra quotes needed (avoid: BABYGPT_APP_PASSWORD="secret" unless you want quotes in the password).
# BABYGPT_APP_PASSWORD=your-shared-password
# BABYGPT_SESSION_SECRET=generate-a-long-random-string
# Optional: call APIs without a browser session (scripts, curl):
# BABYGPT_API_SECRET=another-long-random-string
#
# --- Stripe subscriptions (requires gate + STRIPE_SECRET_KEY) ---
# Dashboard → Developers → API keys: Secret key
# STRIPE_SECRET_KEY=sk_live_...
#
# Dashboard → Developers → Webhooks → Add endpoint:
#   URL: https://<your-host>/api/stripe/webhook
#   Events: checkout.session.completed, customer.subscription.created, customer.subscription.updated,
#           customer.subscription.deleted, invoice.payment_failed
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Optional Checkout tuning (enable Stripe Tax in Dashboard before STRIPE_CHECKOUT_AUTO_TAX):
# STRIPE_CHECKOUT_AUTO_TAX=1
# STRIPE_CHECKOUT_TRIAL_DAYS=0
#
# Optional: keep paid plan access while subscription is past_due (Stripe still retries payment)
# STRIPE_GRACE_PAST_DUE=1
#
# Optional: Stripe Dashboard → Customer Portal → copy Configuration ID (bpc_...)
# STRIPE_PORTAL_CONFIGURATION=bpc_...
#
# Dashboard → Product catalog → each subscription price ID:
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
#
# Public list prices (USD / month) — shown in Plans modal; must match Stripe recurring Prices.
# Without these, paid tiers show "Price on checkout" (Checkout still shows Stripe's total).
# Rough anchors (edit): Starter < Pro ~ near consumer "Plus"-tier positioning; Team = higher pool.
# NEXT_PUBLIC_PLAN_PRICE_STARTER_USD=12
# NEXT_PUBLIC_PLAN_PRICE_PRO_USD=24
# NEXT_PUBLIC_PLAN_PRICE_TEAM_USD=69
#
# --- ProLiant USB sync (PowerShell only; not read by Next.js) ---
# Set in the shell before npm run proliant:usb-sync so the script picks the right drive:
#   $env:BABYGPT_USB_LETTER = "E"
# Optional: skip copying babygpt-standalone when space is tight: BABYGPT_USB_SKIP_STANDALONE=1
# ProLiant ISO download: keep repo on a fixed disk. Scripts refuse staging on USB/SD unless:
#   BABYGPT_ALLOW_REMOVABLE_STAGING=1

# Copy to .env.local for bbGPT, or: npm run env:scaffold  (adds missing empty KEY= lines to .env.local)
# then: npm run env:open
#
# Preferred: Z.AI / GLM — https://open.bigmodel.cn/
# Base URL defaults if omitted.
Z_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
Z_AI_API_KEY=
#
# Fallback: if Z.AI is not configured, bbGPT uses OpenAI Chat Completions instead
# (same UI; web_search uses DuckDuckGo lite unless Z.AI is available).
OPENAI_API_KEY=
#
# --- Gemini (file attachments + Create image) — server-side only (set on Vercel Production for deploys) ---
# Multimodal chat with attachments and /api/gemini/image use Google Gemini. Get a key from AI Studio.
GEMINI_API_KEY=
# Optional model overrides (defaults: gemini-2.5-flash chat, gemini-2.5-flash-image for images):
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
#
# Max upload size per file (bytes). Defaults ~25 MiB when unset (sane for hosted deploys). Raise for self-host, e.g. 536870912 (512 MiB).
# In-app “Max per file” presets store bbgpt_max_file_bytes_override in localStorage (legacy babygpt_max_file_bytes_override); keep server env >= what users can pick.
# Files over BBGPT_INLINE_ATTACHMENT_BYTES use Gemini Files API (POST /api/gemini/files, multipart) so the chat request stays small.
# BBGPT_INLINE_ATTACHMENT_BYTES=
# NEXT_PUBLIC_INLINE_ATTACHMENT_BYTES=
# BBGPT_MAX_FILE_BYTES=
# NEXT_PUBLIC_MAX_FILE_BYTES=
#
# Public URL for Stripe redirects (Checkout success/cancel, Portal return). No trailing slash.
# NEXT_PUBLIC_APP_URL=https://your-domain.example
#
# --- Optional: gated deploy (server wallet + login) ---
# If set, users must sign in at /login; credits & plan are stored under .data/ by default.
# No extra quotes needed (avoid: BBGPT_APP_PASSWORD="secret" unless you want quotes in the password).
# Canonical keys (legacy BABYGPT_* still read when unset): 
# BBGPT_APP_PASSWORD=your-shared-password
# BBGPT_SESSION_SECRET=generate-a-long-random-string
#
# Per-user registration + login (email/password, JWT session) instead of shared app password:
# Set both server + public flags; requires DATABASE_URL and Drizzle migration for table `users`.
# BBGPT_USER_AUTH=1
# NEXT_PUBLIC_BBGPT_USER_AUTH=1
# Optional: call APIs without a browser session (scripts, curl):
# BBGPT_API_SECRET=another-long-random-string
#
# Email sign-in links (/login → forgot panel): comma-separated emails allowed to receive magic links,
# plus any email matching user_wallets.email in Postgres when DATABASE_URL is set.
# Requires Resend + verified sender domain (or Resend onboarding domain for tests):
# BBGPT_MAGIC_LINK_EMAILS=you@gmail.com
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@your-verified-domain.com
#
# --- Postgres (Neon / Vercel Storage — Drizzle) — when set, wallet + billing persist in Postgres ---
# Prefer DATABASE_URL (matches Neon + many hosts). Pull from Neon/Vercel Storage or paste after linking.
# DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# Single-tenant row key until Clerk (optional override):
# BBGPT_WALLET_USER_ID=default
#
# --- Stripe subscriptions (requires gate + STRIPE_SECRET_KEY) ---
# Dashboard → Developers → API keys: Secret key
# STRIPE_SECRET_KEY=sk_live_...
#
# Dashboard → Developers → Webhooks → Add endpoint:
#   URL: https://<your-host>/api/stripe/webhook
#   Events: checkout.session.completed, customer.subscription.created, customer.subscription.updated,
#           customer.subscription.deleted, invoice.payment_failed
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Optional Checkout tuning (enable Stripe Tax in Dashboard before STRIPE_CHECKOUT_AUTO_TAX):
# STRIPE_CHECKOUT_AUTO_TAX=1
# STRIPE_CHECKOUT_TRIAL_DAYS=0
# payment_method_types for Checkout — default in code is card. Add link only if Link is enabled in Stripe Dashboard.
# STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card
#
# Optional: keep paid plan access while subscription is past_due (Stripe still retries payment)
# STRIPE_GRACE_PAST_DUE=1
#
# Optional: Stripe Dashboard → Customer Portal → copy Configuration ID (bpc_...)
# STRIPE_PORTAL_CONFIGURATION=bpc_...
#
# Dashboard → Product catalog → each subscription price ID (or auto-create from Stripe API):
#   npm run stripe:ensure-prices
# Creates monthly ($12/$24/$69) + yearly ($120/$240/$690) Prices when missing; prints STRIPE_PRICE_* lines.
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
#
# Public list prices (USD / month) — shown in Plans modal; must match Stripe recurring Prices.
# Without these, paid tiers show "Price on checkout" (Checkout still shows Stripe's total).
# Rough anchors (edit): Starter < Pro ~ near consumer "Plus"-tier positioning; Team = higher pool.
# NEXT_PUBLIC_PLAN_PRICE_STARTER_USD=12
# NEXT_PUBLIC_PLAN_PRICE_PRO_USD=24
# NEXT_PUBLIC_PLAN_PRICE_TEAM_USD=69
#
# Annual list prices (USD / year) — Plans modal when “Annual” is selected. Defaults: $120 / $240 / $690 if unset.
# NEXT_PUBLIC_PLAN_PRICE_STARTER_YEARLY_USD=120
# NEXT_PUBLIC_PLAN_PRICE_PRO_YEARLY_USD=240
# NEXT_PUBLIC_PLAN_PRICE_TEAM_YEARLY_USD=690
#
# Yearly recurring Stripe Price IDs (Product catalog → add Price → recurring yearly). Required for annual Checkout.
# STRIPE_PRICE_STARTER_YEARLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_TEAM_YEARLY=price_...
#
# --- ProLiant USB sync (PowerShell only; not read by Next.js) ---
# Set in the shell before npm run proliant:usb-sync so the script picks the right drive:
#   $env:BBGPT_USB_LETTER = "E"
# Legacy: BABYGPT_USB_LETTER. Optional: skip copying bbgpt-standalone when space is tight: BBGPT_USB_SKIP_STANDALONE=1 (legacy BABYGPT_USB_SKIP_STANDALONE)
# ProLiant ISO download: keep repo on a fixed disk. Scripts refuse staging on USB/SD unless:
#   BBGPT_ALLOW_REMOVABLE_STAGING=1

# ===========================================
# POSTFORGE + UNIFIED CONTENT STUDIO
# Copy to .env.local and fill in values.
# ===========================================

# DATABASE — use your Postgres URL (schema targets PostgreSQL)
# Example Neon / local Postgres:
DATABASE_URL="postgresql://user:password@localhost:5432/postforge"

# OPENAI (Postforge /api/generate + Unified DALL·E 3 /api/unified/images/generate)
OPENAI_API_KEY=

# Optional: Cloudflare R2 (S3-compatible) — if unset, generated images stay under public/uploads/
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://your-bucket.r2.dev

# ANTHROPIC — required for /unified AI chat (/api/unified/chat)
ANTHROPIC_API_KEY=

# NEXTAUTH
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# UPSTASH (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# INNGEST (optional)
INNGEST_EVENT_KEY=

# META — Phase 3 publishing
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_USER_ID=
IG_ACCESS_TOKEN=
META_API_VERSION=v21.0

# STRIPE — Unified checkout + webhooks
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Dashboard → Products → Prices (recurring monthly)
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

# Admin revenue API: GET /api/admin/revenue — Authorization: Bearer <secret> or ?key=
ADMIN_REVENUE_SECRET=

# CLOUDINARY (optional CDN for uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=content_studio_uploads

# PUSH / EMAIL
FCM_SERVER_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# REDIS (optional)
REDIS_URL=redis://localhost:6379

# APP URL (absolute URLs for uploads in production)
APP_URL=http://localhost:3000

NODE_ENV=development

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Cursor / IDE
.cursor/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Z.AI local config (may contain API keys)
.z-ai-config

# Server wallet (when BABYGPT_APP_PASSWORD is set)
.data/

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.production.template
deploy/secrets.preview.env

# ProLiant staging (ISO + zip built locally)
deploy/proliant/staging/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Local user uploads (dev)
public/uploads/*
!public/uploads/.gitkeep
